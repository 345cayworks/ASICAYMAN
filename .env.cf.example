# Copy to .env.cf (gitignored) and fill in. Used by scripts/cf-bootstrap.sh.
# Never commit the real .env.cf — secrets only live in Cloudflare's secret
# store (pushed by the bootstrap script) and on your machine.

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Database — Neon pooled connection string. The bootstrap script will run
# `prisma db push` against this URL to apply the schema and seed the admin.
DATABASE_URL=

# Auth.js v5
# Generate a fresh one with:  openssl rand -base64 32
AUTH_SECRET=
# Production URL the Worker will serve at.
NEXTAUTH_URL=https://abc.345guide.com

# Seed admin (Prisma seed picks these up on first apply).
SEED_ADMIN_EMAIL=admin@345guide.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Adventist Business Community Admin

# Optional
AD_ENGINE_KEY=
