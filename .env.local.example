# -----------------------------------------------------------------------------
# COPY THIS FILE TO `.env.local` in the same folder, paste your value between
# the quotes, save, then run `npm run ads:sync`.
#
# `.env.local` is gitignored — your secret NEVER gets committed to GitHub.
# -----------------------------------------------------------------------------

# The secret that authorises this app to talk to the Cayworks Ad Engine.
# Get it from Netlify:
#   Netlify dashboard → your ASI Cayman site → Site configuration →
#   Environment variables → find AD_ENGINE_KEY → "Show value" → copy → paste
#   between the quotes below.
#
# If AD_ENGINE_KEY doesn't exist in Netlify yet, ask Cayworks for the value
# and add it there too so the deployed site also picks it up.
AD_ENGINE_KEY=""

# Optional — leave these commented out unless Cayworks specifically tells you
# to override them.
# AD_ENGINE_BASE_URL="https://ads.cayworks.com"
# AD_ENGINE_PLATFORM="asicayman"

# ---------- Blog AI generator (optional) ----------
# Anthropic API key — enables the "Generate with AI" blog button. Leave blank
# to keep the feature hidden.
TEXT_LLM_API_KEY=""
# Shared secret for the internal cron routes; must match what you set in
# Netlify. Generate one with: openssl rand -hex 32
CRON_SECRET=""
# OpenAI API key — enables the "Generate images" button (cover + in-text).
# Leave blank to keep the feature hidden.
IMAGE_API_KEY=""
