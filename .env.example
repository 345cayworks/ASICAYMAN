# ---------- Database (Neon) ----------
# Pooled connection string for the app (use PgBouncer / pooled URL in production)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/asi_cayman?sslmode=require&pgbouncer=true&connect_timeout=15"
# Direct (unpooled) URL for migrations
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/asi_cayman?sslmode=require"

# ---------- Auth.js (NextAuth v5) ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-random-string"
# Public URL of the app. In dev: http://localhost:3000.
# In production: https://abc.345guide.com (set in Netlify environment variables).
NEXTAUTH_URL="http://localhost:3000"
# Trust the host header on Netlify.
AUTH_TRUST_HOST="true"

# ---------- Email (optional, for magic links and contact form) ----------
EMAIL_FROM="ASI Cayman <noreply@asicayman.org>"
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
CONTACT_INBOX="asicayman@gmail.com"

# ---------- File storage ----------
# In production on Netlify, leave these blank — Netlify Blobs is auto-configured.
# For local dev, files are written to ./.uploads (gitignored).
STORAGE_DRIVER="local"   # "local" | "netlify-blobs"

# ---------- Cayworks Ad Engine ----------
# SECRET — set in Netlify env, never commit a real value. Ads are disabled
# (slots render nothing) when this is unset.
AD_ENGINE_KEY=""
# Optional overrides (sensible defaults baked in):
# AD_ENGINE_BASE_URL="https://ads.cayworks.com"
# AD_ENGINE_PLATFORM="asicayman"

# ---------- Seed admin (used by prisma/seed.ts) ----------
SEED_ADMIN_EMAIL="admin@asicayman.org"
SEED_ADMIN_PASSWORD="ChangeMe-Immediately-2026"
SEED_ADMIN_NAME="ASI Cayman Admin"

# ---------- Blog AI generator (optional) ----------
# Anthropic key for the AI blog post generator. When unset, the "Generate with
# AI" button is hidden and the daily generate cron no-ops.
TEXT_LLM_API_KEY=""
# Optional model override (default: claude-sonnet-5).
# TEXT_LLM_MODEL="claude-sonnet-5"
# Shared secret the Netlify scheduled functions send to the internal cron
# routes (/api/cron/blog-*). Generate with: openssl rand -hex 32
CRON_SECRET=""
# OpenAI key for the two-image generator (cover + in-text). When unset, the
# "Generate images" button is hidden. Needs TEXT_LLM_API_KEY too (art director).
IMAGE_API_KEY=""
# Optional image-model override (default: gpt-image-1).
# IMAGE_MODEL="gpt-image-1"
